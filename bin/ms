#!/usr/bin/env bash

set -euo pipefail

PROJECT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." &> /dev/null && pwd )"
cd "${PROJECT_DIR}"

if [[ $# -eq 0 ]]; then
    if python -c "import textual, pynvml" >/dev/null 2>&1; then
        exec python "bin/ms_tui.py"
    fi
    echo "错误: 启动 TUI 需要强制依赖 textual + pynvml。"
    echo "请先安装: pip install -r modelServer/requirements.txt"
    exit 1
fi

exec python "bin/ms_cli.py" "$@"